rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Admin lookup - Note: The user email from runtime will be used as a seed for admins if needed
    // In this app, we'll assume admins are in the 'admins' collection
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // 1. Artisans
    match /artisans/{artisanId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admins manage artisans for now to ensure authenticity

      function isValidArtisan(data) {
        return data.keys().hasAll(['name', 'tribe', 'story', 'photoUrl']) &&
               data.keys().size() >= 4 &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.tribe is string && data.tribe.size() > 0 && data.tribe.size() <= 50 &&
               data.story is string && data.story.size() > 0 && data.story.size() <= 2000 &&
               data.photoUrl is string && data.photoUrl.size() <= 500;
      }
    }

    // 2. Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin(); // Marketplace integrity

      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'price', 'artisanId', 'images']) &&
               data.price is number && data.price > 0 &&
               data.artisanId is string && exists(/databases/$(database)/documents/artisans/$(data.artisanId)) &&
               data.images is list && data.images.size() > 0 && data.images.size() <= 10;
      }
    }

    // 3. Orders
    match /orders/{orderId} {
      allow get: if isVerified() && isOwner(existing().buyerId);
      allow list: if isVerified() && resource.data.buyerId == request.auth.uid;
      
      allow create: if isVerified() && 
                    isOwner(incoming().buyerId) && 
                    isValidOrder(incoming()) &&
                    exists(/databases/$(database)/documents/products/$(incoming().productId));

      allow update: if isVerified() && isAdmin(); // Only admins can update status etc.

      function isValidOrder(data) {
        return data.keys().hasAll(['buyerId', 'productId', 'quantity', 'total', 'status']) &&
               data.quantity is int && data.quantity > 0 &&
               data.status == 'Pending' &&
               data.total is number && data.total > 0;
      }
    }

    // 4. Users (Split Pattern)
    match /users/{userId} {
      match /public/profile {
        allow read: if true;
        allow write: if isVerified() && isOwner(userId) && isValidProfile(incoming());
      }
      match /private/info {
        allow read: if isVerified() && isOwner(userId);
        allow write: if isVerified() && isOwner(userId) && isValidPrivate(incoming());
      }
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['displayName', 'photoURL']) &&
             data.displayName is string && data.displayName.size() <= 50;
    }

    function isValidPrivate(data) {
      return data.keys().hasAll(['email', 'address']) &&
             data.email == request.auth.token.email; // Integrity check
    }
  }
}
